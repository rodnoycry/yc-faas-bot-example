# --- Yandex Cloud Function metadata (used by `pnpm run deploy`) ---

# Name of the YCF function (created once via `yc serverless function create`)
YC_FUNCTION_NAME="yc-faas-ai-bot-example"

# Service account ID attached to the function. Must have ydb.editor on the
# folder containing your YDB database.
YC_SERVICE_ACCOUNT_ID="ajeXXXXXXXXXXXXXXXXX"

# --- Function runtime variables (passed via --environment on deploy) ---

# YDB grpcs connection string from the database overview page.
YDB_CONNECTION_STRING="grpcs://ydb.serverless.yandexcloud.net:2135/?database=/ru-central1/.../..."

# Public function URL — set after the first deploy. Trailing slash is fine.
DEPLOYMENT_URL="https://functions.yandexcloud.net/d4eXXXXXXXXXXXXXXXXX"

# Telegram bot token from @BotFather
BOT_TOKEN="xxxxxxxxxx:xxxxxxx-xxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Bot info from https://api.telegram.org/bot<BOT_TOKEN>/getMe (single-quoted)
BOT_INFO='{
    "id": 1234567890,
    "is_bot": true,
    "first_name": "mybot",
    "username": "MyBot",
    "can_join_groups": true,
    "can_read_all_group_messages": false,
    "supports_inline_queries": true,
    "can_connect_to_business": false
}'

# OpenAI-compatible LLM endpoint
LLM_API_BASE_URL="https://your-api-endpoint.com/v1"
LLM_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxx"
LLM_MODEL="your-model-name"

# --- Local-only (NOT used inside the function) ---

# IAM token for local YDB access. Get a fresh one via `yc iam create-token`
# (token starts with `t1...`). Inside YCF this is not needed — auth comes
# from the attached service account via the metadata endpoint.
YDB_ACCESS_TOKEN_CREDENTIALS="t1.xxxxx"
